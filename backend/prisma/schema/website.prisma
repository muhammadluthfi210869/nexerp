model Article {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  content         String
  publishedAt     DateTime @default(now())
  metaDescription String?  @db.VarChar(255)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@map("articles")
}

model WebsiteProduct {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  content         String
  category        String
  publishedAt     DateTime @default(now())
  metaDescription String?  @db.VarChar(255)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@map("website_products")
}
