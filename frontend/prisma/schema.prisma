generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
}


model User {
  id               String           @id @default(uuid()) @db.Uuid
  fullName         String?
  email            String           @unique
  passwordHash     String?
  roles            UserRole[]
  status           UserStatus       @default(ACTIVE)
  managerPin       String? // Phase 2: Escalation PIN
  approvalPin      String? // Internal E-Signature PIN (APJ/Legal)
  createdAt        DateTime         @default(now())
  deletedAt        DateTime?
  stateTransitionLogs StateTransitionLog[] @relation("StateChanger")
  bussdevProfile   BussdevStaff?
  verifiedAds      DailyAdsMetric[] @relation("AdsVerifier")
  lockedFormulas   Formula[]        @relation("FormulaLockedBy")
  approvedFunds    FundRequest[]    @relation("FundApprover")
  disbursedFunds   FundRequest[]    @relation("FundDisburser")
  fundRequests     FundRequest[]    @relation("FundRequester")
  guestLogs        GuestLog[]
  labTests         LabTestResult[]
  lostDeals        LostDeal[]
  verifiedPayments Payment[]        @relation("FinanceVerifier")
  prodPlans        ProductionPlan[] @relation("ProdAdmin")
  scmPO            PurchaseOrder[]  @relation("SCMProcessor")
  qcAudits         QCAudit[]        @relation("QCOfficer")
  registrations    RegulatoryPipeline[]   @relation("LegalPIC")
  leadsManaged     SalesLead[]      @relation("BDLeads")
  salesTargets     SalesTarget[]
  rndSamples       SampleRequest[]  @relation("RNDFormulator")
  logistics        Shipment[]       @relation("LogisticsOfficer")
  laborGrade       LaborGrade?
  escalationsApproved AuditEscalation[] @relation("EscalationApprover")
  employeeProfile  Employee?
  approvedTickets  Ticket[]         @relation("TicketApprover")
  authorizedPayrolls Payroll[]      @relation("PayrollApprover")

  @@map("users")
}


model SalesLead {
  id                  String            @id @default(uuid()) @db.Uuid
  clientName          String
  brandName           String?
  contactInfo         String
  source              String
  productInterest     String
  estimatedValue      Decimal           @default(0) @db.Decimal(15, 2)
  status              WorkflowStatus    @default(NEW_LEAD)
  lostReason          LostReason?
  picId               String            @db.Uuid
  isRepeatOrder       Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime?         @updatedAt
  hkiMode             HkiMode           @default(NEW)
  paymentType         PaymentType       @default(PREPAID)
  lastFollowUpAt      DateTime?
  marginPercentage    Decimal           @default(0) @db.Decimal(5, 2)
  moq                 Int               @default(0)
  planOmset           Decimal           @default(0) @db.Decimal(15, 2)
  categoryEnum        ProductCategory?
  categoryId          String?           @db.Uuid
  province            String?
  city                String?
  district            String?
  addressDetail       String?
  campaignName        String?
  isHighValue         Boolean           @default(false)
  slaStart            DateTime?         @db.Timestamp(6)
  bdId                String?           @db.Uuid
  email               String?
  contactChannel      String?
  launchingPlan       String?
  targetMarket        String?
  designSuggestion    String?
  notes               String?
  packagingSuggestion String?
  sku                 String?
  unitPrice           Decimal?          @db.Decimal(15, 2)
  valueSuggestion     String?
  convertedToProdAt   DateTime?
  convertedToSampleAt DateTime?
  firstFollowUpAt     DateTime?
  isEmergencyOverride Boolean           @default(false)
  lastStageAt         DateTime          @default(now())
  orderCount          Int               @default(0)
  overrideNote        String?
  statusDuration      Int               @default(0)
  wonAt               DateTime?
  formulaId           String?           @db.Uuid
  isFormulaLocked     Boolean           @default(false)
  spkFileUrl          String?
  logoRevision        Int               @default(0)
  hkiProgress         String?
  activityStreams     ActivityStream[]
  designTasks         DesignTask[]
  activities          LeadActivity[]
  timelineLogs        LeadTimelineLog[]
  lostDeal            LostDeal?
  npfs                NewProductForm[]
  purchaseOrders      PurchaseOrder[]
  registrations       RegulatoryPipeline[]
  retention           RetentionEngine?
  bd                  User?             @relation("BDLeads", fields: [bdId], references: [id])
  category            MasterCategory?   @relation("CustomerToCategory", fields: [categoryId], references: [id])
  pic                 BussdevStaff      @relation(fields: [picId], references: [id])
  salesOrders         SalesOrder[]
  sampleRequests      SampleRequest[]
  workOrders          WorkOrder[]

  @@map("sales_leads")
}

model LeadActivity {
  id               String       @id @default(uuid()) @db.Uuid
  leadId           String       @db.Uuid
  activityType     ActivityType
  notes            String
  responseTime     Int?
  createdAt        DateTime     @default(now())
  sequenceNumber   Int          @default(1)
  amount           Decimal?     @db.Decimal(15, 2)
  fileUrl          String?
  fileUrlSecondary String?
  metadata         Json?
  isValidated      Boolean      @default(false)
  validatedBy      String?      @db.Uuid
  lead             SalesLead    @relation(fields: [leadId], references: [id])

  @@map("lead_activities")
}

model LostDeal {
  id         String     @id @default(uuid()) @db.Uuid
  leadId     String     @unique @db.Uuid
  bdId       String     @db.Uuid
  stageLost  LostStage
  reasonType LostReason
  lostValue  Decimal?   @db.Decimal(15, 2)
  notes      String?
  createdAt  DateTime   @default(now())
  bd         User       @relation(fields: [bdId], references: [id])
  lead       SalesLead  @relation(fields: [leadId], references: [id])

  @@map("lost_deals")
}

model BussdevStaff {
  id             String      @id @default(uuid()) @db.Uuid
  name           String
  targetRevenue  Decimal     @default(0) @db.Decimal(15, 2)
  isActive       Boolean     @default(true)
  userId         String?     @unique @db.Uuid
  avgClosingDays Float       @default(0)
  totalLeads     Int         @default(0)
  totalLost      Int         @default(0)
  totalWon       Int         @default(0)
  user           User?       @relation(fields: [userId], references: [id])
  salesLeads     SalesLead[]

  @@map("bussdev_staffs")
}

model GuestLog {
  id              String        @id @default(uuid()) @db.Uuid
  visitDate       DateTime      @default(now())
  clientName      String
  bdId            String        @db.Uuid
  productInterest String?
  moqPlan         Int?
  category        GuestCategory
  phoneNo         String?
  instansi        String?
  purpose         String?
  city            String?
  email           String?
  launchingPlan   String?
  targetMarket    String?
  bd              User          @relation(fields: [bdId], references: [id])

  @@map("guest_logs")
}

model NewProductForm {
  id           String          @id @default(uuid()) @db.Uuid
  leadId       String          @db.Uuid
  productName  String
  targetPrice  Decimal         @db.Decimal(15, 2)
  conceptNotes String?
  status       NPFStatus       @default(PENDING)
  lead         SalesLead       @relation(fields: [leadId], references: [id])
  samples      SampleRequest[]

  @@map("new_product_forms")
}

model SalesOrder {
  id                String           @id @default(uuid()) @db.Uuid
  orderNumber       String           @unique
  transactionDate   DateTime         @default(now())
  dueDate           DateTime?
  leadId            String           @db.Uuid
  sampleId          String           @db.Uuid
  totalAmount       Decimal          @db.Decimal(15, 2)
  quantity          Int              @default(1)
  status            SOStatus         @default(PENDING_DP)
  salesCategory     String?
  brandName         String?
  taxId             String?          @db.Uuid
  currencyId        String?          @db.Uuid
  netto             Decimal?         @db.Decimal(10, 2)
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  stockStatus       StockStatus      @default(PENDING_CHECK)
  designTasks       DesignTask[]
  invoices          Invoice[]
  workOrders        ProductionPlan[]
  items             SalesOrderItem[]
  currency          Currency?        @relation(fields: [currencyId], references: [id])
  lead              SalesLead        @relation(fields: [leadId], references: [id])
  sample            SampleRequest    @relation(fields: [sampleId], references: [id])
  tax               TaxRate?         @relation(fields: [taxId], references: [id])
  returns           SalesReturn[]
  shipments         Shipment[]
  journalEntries    JournalEntry[]
  kpiLogs           KpiPointLog[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id             String         @id @default(uuid()) @db.Uuid
  soId           String         @db.Uuid
  sampleId       String?        @db.Uuid
  productName    String
  netto          Decimal        @db.Decimal(10, 2)
  quantity       Int
  unitPrice      Decimal        @db.Decimal(15, 2)
  taxId          String?        @db.Uuid
  subtotal       Decimal        @db.Decimal(15, 2)
  materialItemId String?        @db.Uuid
  materialItem   MaterialItem?  @relation(fields: [materialItemId], references: [id])
  sample         SampleRequest? @relation(fields: [sampleId], references: [id])
  salesOrder     SalesOrder     @relation(fields: [soId], references: [id])
  tax            TaxRate?       @relation(fields: [taxId], references: [id])

  @@map("sales_order_items")
}

model SalesReturn {
  id           String            @id @default(uuid()) @db.Uuid
  returnDate   DateTime          @default(now())
  soId         String            @db.Uuid
  warehouseId  String            @db.Uuid
  notes        String
  returnStatus String            @default("POTONG_TAGIHAN")
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  items        SalesReturnItem[]
  so           SalesOrder        @relation(fields: [soId], references: [id])
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id])
  journalEntries JournalEntry[]

  @@map("sales_returns")
}

model SalesReturnItem {
  id          String       @id @default(uuid()) @db.Uuid
  returnId    String       @db.Uuid
  materialId  String       @db.Uuid
  qtyOriginal Decimal      @db.Decimal(15, 2)
  qtyReturned Decimal      @db.Decimal(15, 2)
  material    MaterialItem @relation(fields: [materialId], references: [id])
  return      SalesReturn  @relation(fields: [returnId], references: [id])

  @@map("sales_return_items")
}

model RetentionEngine {
  id               String          @id @default(uuid()) @db.Uuid
  leadId           String          @unique @db.Uuid
  estDepletionDate DateTime?
  status           RetentionStatus @default(WAITING)
  lead             SalesLead       @relation(fields: [leadId], references: [id])

  @@map("retention_engine")
}



model LeadTimelineLog {
  id            String           @id @default(uuid()) @db.Uuid
  leadId        String           @db.Uuid
  action        String
  previousStatus WorkflowStatus?
  newStatus      WorkflowStatus?
  notes         String?
  createdAt     DateTime         @default(now())
  loggedBy      String
  category      ActivityCategory @default(OTHER)
  lead          SalesLead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_timeline_logs")
}

model ActivityStream {
  id               String          @id @default(uuid()) @db.Uuid
  leadId           String          @db.Uuid
  senderDivision   Division
  eventType        StreamEventType
  payload          Json?
  notes            String?
  loggedBy         String?
  createdAt        DateTime        @default(now())
  deadlineAt       DateTime?
  expectedDuration Int?
  isCritical       Boolean         @default(false)
  lead             SalesLead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("activity_streams")
}


model DesignTask {
  id              String           @id @default(uuid()) @db.Uuid
  leadId          String           @db.Uuid
  soId            String?          @db.Uuid
  brief           String
  kanbanState     DesignState      @default(INBOX)
  
  // Stats & Interlocks
  revisionCount   Int              @default(0)
  isLocked        Boolean          @default(false)
  isFinal         Boolean          @default(false)
  
  // SLA
  slaDeadline     DateTime?
  
  // Final Assets (LOCKED state only)
  finalArtworkUrl String?
  finalMockupUrl  String?
  
  // Timestamps
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relations
  lead            SalesLead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  salesOrder      SalesOrder?      @relation(fields: [soId], references: [id])
  versions        DesignVersion[]
  feedbacks       DesignFeedback[]

  @@map("design_tasks")
}

model DesignVersion {
  id              String       @id @default(uuid()) @db.Uuid
  taskId          String       @db.Uuid
  versionNumber   Int
  
  // Assets
  artworkUrl      String?      // The High-Res Master File
  mockupUrl       String?      // The visual preview
  
  // Tech Specs (Tab A/B)
  printSpecs      Json?        // Finishing, Paper Type, etc.
  
  createdAt       DateTime     @default(now())
  uploadedBy      String?      @db.Uuid
  
  task            DesignTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("design_versions")
}

model DesignFeedback {
  id              String          @id @default(uuid()) @db.Uuid
  taskId          String          @db.Uuid
  fromDivision    Division
  authorId        String          @db.Uuid
  
  content         String?
  approvalStatus  ApprovalStatus?
  
  // Legal E-Signature (PIN verification meta)
  signatureHash   String?         // Hash of the PIN + Meta
  ipAddress       String?
  
  createdAt       DateTime        @default(now())
  
  task            DesignTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("design_feedbacks")
}


