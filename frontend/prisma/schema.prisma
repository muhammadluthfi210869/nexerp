model Invoice {
  id                String          @id @default(uuid()) @db.Uuid
  invoiceNumber     String          @unique
  category          InvoiceCategory
  type              InvoiceType     @default(FINAL_PAYMENT)
  status            InvoiceStatus   @default(UNPAID)
  amountDue         Decimal         @db.Decimal(15, 2)
  outstandingAmount Decimal         @db.Decimal(15, 2)
  issuedAt          DateTime        @default(now())
  dueDate           DateTime
  paidAt            DateTime?
  soId              String?         @db.Uuid
  poId              String?         @db.Uuid
  workOrderId       String?         @db.Uuid
  deliveryOrderId   String?         @unique @db.Uuid
  supplierId        String?         @db.Uuid
  attachmentUrls    String[]        @default([])
  notes             String?
  description       String?
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  so                SalesOrder?     @relation(fields: [soId], references: [id])
  po                PurchaseOrder?  @relation(fields: [poId], references: [id])
  supplier          Supplier?       @relation(fields: [supplierId], references: [id])
  workOrder         WorkOrder?      @relation(fields: [workOrderId], references: [id])
  deliveryOrder     DeliveryOrder?  @relation(fields: [deliveryOrderId], references: [id])
  payments          Payment[]
  journalEntries    JournalEntry[]

  @@map("unified_invoices")
}

model Account {
  id                    String            @id @default(uuid()) @db.Uuid
  code                  String            @unique
  name                  String
  isActive              Boolean           @default(true)
  type                  AccountType
  normalBalance         NormalBalance
  parentId              String?           @db.Uuid
  reclassifyToAccountId String?           @db.Uuid
  reportGroup           ReportGroup?      @default(OTHER_EXPENSE)
  parent                Account?          @relation("AccountTree", fields: [parentId], references: [id])
  children              Account[]         @relation("AccountTree")
  reclassifyToAccount   Account?          @relation("Reclassification", fields: [reclassifyToAccountId], references: [id])
  reclassifiedFrom      Account[]         @relation("Reclassification")
  journalLines          JournalLine[]
  taxLines              JournalLine[]     @relation("TaxAccount")
  goodsInventory        MaterialItem[]    @relation("InventoryAccount")
  goodsSales            MaterialItem[]    @relation("SalesAccount")
  paymentAccounts       Payment[]         @relation("PaymentAccount")
  lossAccounts          RejectExecution[] @relation("LossAccount")
  adjustmentAccounts    StockAdjustment[] @relation("AdjustmentAccount")

  @@map("accounts")
}

model FinancialPeriod {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  startDate DateTime
  endDate   DateTime
  status    PeriodStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  summaryLedgers FinancialSummaryLedger[]
  payrolls       Payroll[]
  kpiScores      KpiScore[]

  @@map("financial_periods")
}

model StockAdjustment {
