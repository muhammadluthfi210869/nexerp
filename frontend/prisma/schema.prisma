  goodQty         Decimal         @db.Decimal(15, 2)
  quarantineQty   Decimal         @db.Decimal(15, 2)
  rejectQty       Decimal         @db.Decimal(15, 2)
  shrinkageQty    Decimal         @default(0) @db.Decimal(15, 2)
  startTime       DateTime?
  endTime         DateTime?
  loggedAt        DateTime        @default(now())
  machineId       String?         @db.Uuid
  operatorId      String?         @db.Uuid
  downtimeMinutes Int             @default(0)
  notes           String?
  laborCost       Decimal?        @db.Decimal(15, 2)
  overheadCost    Decimal?        @db.Decimal(15, 2)
  actualLaborRate   Decimal?      @db.Decimal(10, 2)
  actualMachineRate Decimal?      @db.Decimal(10, 2)
  /// Snapshot value of the material/result at the time of log
  unitValueAtTransaction Decimal? @db.Decimal(15, 2)
  /// Link to specific material batch being consumed or produced
  materialInventoryId String?     @db.Uuid
  machineParams   Json?           @db.JsonB
  machine         Machine?        @relation(fields: [machineId], references: [id])
  materialInventory MaterialInventory? @relation(fields: [materialInventoryId], references: [id])
  plan            ProductionPlan? @relation("PlanLogs", fields: [planId], references: [id])
  workOrder       WorkOrder?      @relation(fields: [workOrderId], references: [id])
  qcAudits        QCAudit[]

  @@index([loggedAt])
  @@index([stage])
  @@index([workOrderId])
  @@map("production_logs")
}

